# Server
NODE_ENV=development
PORT=3001
APP_URL=http://127.0.0.1:3001
ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# Supabase — keep the service-role key server-side only
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash

# Stripe
STRIPE_SECRET_KEY=sk_test_or_live
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Optional: use saved Stripe Price IDs instead of inline price_data
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_BUSINESS=

# Optional observability / internal webhook protection
SENTRY_DSN=
WEBHOOK_SECRET=
