{
  "name": "creditos",
  "version": "2.0.0",
  "description": "CREDITOS — AI credit repair + funding readiness platform (Express backend + single-page app)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test tests/*.test.js",
    "validate:env": "node scripts/validate-env.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "build": "node scripts/build-check.mjs",
    "launch:check": "npm run validate:env && npm run typecheck && npm run lint --if-present && npm test && npm run build"
  },
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "node-fetch": "^3.3.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": "22.x"
  }
}
